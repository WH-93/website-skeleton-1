generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String
  type        String   @default("Full-time")
  sector      String   @default("Practice")
  salary      String?
  description String
  slug        String   @unique
  status      String   @default("Live") // Live, Draft, Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
}

model Candidate {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  cvKey     String?
  cvName    String?
  createdAt DateTime @default(now())

  applications Application[]
}

model Application {
  id        String   @id @default(cuid())
  status    String   @default("Applied")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobId       String
  job         Job       @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@unique([jobId, candidateId])
}
